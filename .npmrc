# Expo / React Native requieren un node_modules PLANO (no el enlazado por defecto de
# pnpm), o Metro y el autolinking nativo fallan.
node-linker=hoisted

# El ecosistema RN tiene muchos peer deps desalineados; sin esto pnpm abortaría la
# instalación. No afecta a la integridad/seguridad de los paquetes (eso lo garantiza
# el lockfile + verificación de checksums de pnpm).
strict-peer-dependencies=false
